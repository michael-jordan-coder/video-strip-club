{
  "name": "video-strip-club",
  "version": "0.1.0",
  "description": "Open-source video optimization for web delivery — CLI, web frontend, and Claude Code subagent under one monorepo.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "vsc": "npm --workspace @vsc/cli run vsc --",
    "strip-club": "npm --workspace @vsc/tui run vsc-ui --",
    "strip club": "npm --workspace @vsc/tui run vsc-ui --",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "build": "npm run --workspaces --if-present build"
  },
  "engines": {
    "node": ">=20"
  }
}
